@{
    ViewData["Title"] = "Ürün Mağazası";
}

<div class="text-center">
    <h1 class="display-4 fw-bold text-primary mb-5">HOŞ GELDİN SEVDİ</h1>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card shadow-lg border-0">
                <img src="/images/saat.jpg" class="card-img-top p-3" alt="Akıllı Saat" style="height: 250px; object-fit: contain;">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Akıllı Saat</h5>
                    <p class="card-text text-muted">Modern ve şık tasarım.</p>
                    <button class="btn btn-primary px-4">Satın Al</button>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card shadow-lg border-0">
                <img src="/images/kulaklik.jpg" class="card-img-top p-3" alt="Kulaklık" style="height: 250px; object-fit: contain;">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Kablosuz Kulaklık</h5>
                    <p class="card-text text-muted">Yüksek kaliteli ses deneyimi.</p>
                    <button class="btn btn-primary px-4">Satın Al</button>
                </div>
            </div>
        </div>
    </div>
</div>